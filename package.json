{
  "name": "livesound",
  "version": "1.0.0",
  "description": "Unified media player for Spotify and YouTube Music",
  "author": "ccd-69",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --config vite.renderer.config.ts",
    "dev:electron": "npm run build:main && npm run build:preload && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload && vite build --config vite.renderer.config.ts",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.ccd69.livesound",
    "productName": "LiveSound",
    "copyright": "Copyright © 2025 ccd-69",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "asar": true,
    "win": {
      "icon": "icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "license": "LICENSE.txt"
    },
    "mac": {
      "icon": "icons/icon.png",
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "icon": "icons/icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "icons/icon.png",
      "category": "AudioVideo",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "desktop": {
        "entry": {
          "Name": "LiveSound",
          "Comment": "Unified media player for Spotify and YouTube Music",
          "Categories": "AudioVideo;Audio;Player;",
          "StartupWMClass": "LiveSound"
        }
      },
      "maintainer": "ccd-69",
      "vendor": "ccd-69",
      "synopsis": "Unified media player",
      "description": "A unified media player integrating Spotify and YouTube Music with custom themes."
    },
    "publish": {
      "provider": "github",
      "owner": "ccd-69",
      "repo": "LiveSound"
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.0",
    "vite": "^6.4.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-forge": "^1.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0"
  }
}
